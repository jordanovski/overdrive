# Container image to run.
OVERDRIVE_IMAGE=ghcr.io/jordanovski/overdrive:latest

# Host path where model folders live. Required.
OVERDRIVE_HUB_ROOT=/raid/huggingface

# Host port exposed by the Overdrive web service.
OVERDRIVE_WEB_PORT=8080

# Logging level for the Overdrive app.
OVERDRIVE_LOG_LEVEL=INFO

# Runtime host used by benchmark jobs to call launched vLLM endpoints.
# Use host.docker.internal for compose/docker bridge networking.
OVERDRIVE_RUNTIME_HOST=host.docker.internal

# Optional explicit profiles file path inside the container.
# OVERDRIVE_PROFILES=/root/.config/overdrive/profiles.yaml

# Optional Hugging Face token used by datasets/hub requests (recommended for SWE-bench).
HF_TOKEN=

# Optional Hugging Face token name used by some tooling and vLLM flows.
HUGGING_FACE_HUB_TOKEN=